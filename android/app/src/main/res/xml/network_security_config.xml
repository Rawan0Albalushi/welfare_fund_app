<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <!-- IP جهازك على الشبكة المحلية (غيّره إذا كان مختلفاً) -->
    <domain includeSubdomains="true">192.168.100.66</domain>
    <!-- أي IP في الشبكة المحلية 192.168.x.x (للاختبار) -->
    <domain includeSubdomains="true">192.168.1.1</domain>
    <!-- محاكي أندرويد: 10.0.2.2 = localhost على الكمبيوتر -->
    <domain includeSubdomains="true">10.0.2.2</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
    <domain includeSubdomains="true">localhost</domain>
    <!-- إذا كان IP جهازك مختلفاً أضفه هنا ثم أعد بناء التطبيق -->
  </domain-config>
</network-security-config>
